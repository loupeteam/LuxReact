{
  "name": "@loupeteam/lux-react",
  "version": "0.0.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "description": "React hooks for connecting to industrial machines (PLCs)",
  "license": "MIT",
  "author": "Loupe",
  "homepage": "https://github.com/loupeteam/LuxReact#readme",
  "bugs": {
    "url": "https://github.com/loupeteam/LuxReact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loupeteam/LuxReact.git"
  },
  "keywords": [
    "react",
    "plc",
    "industrial",
    "automation",
    "opc-ua"
  ],
  "type": "module",
  "main": "./dist/lux-react.umd.cjs",
  "module": "./dist/lux-react.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/lux-react.js",
      "require": "./dist/lux-react.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
